Program 1 (Printing 1-10 in each line as nested loop)
#include <iostream>
using namespace std;
int main() {
    for(int i=1; i<=10; i++){
        for(int j=1; j<=10; j++){
            cout << j;
          }
          cout << '\n';
    } 
    
    return 0;
}

