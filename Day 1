Program 6 (Alphabet case checker)
#include <iostream>
using namespace std;

int main() {
    char ch;

    cout << "Enter an alphabet: ";
    cin >> ch;

    // Check if input is an alphabet
    if ((ch >= 'A' && ch <= 'Z') || (ch >= 'a' && ch <= 'z')) {
        
        // Check for uppercase
        if (ch >= 'A' && ch <= 'Z') {
            cout << "Uppercase Alphabet";
        }
        // Otherwise lowercase
        else {
            cout << "Lowercase Alphabet";
        }

    } else {
        cout << "Not an alphabet";
    }

    return 0;
}


Program 7 (Age group classifier)
#include <iostream>
using namespace std;

int main() {
    int age;

    cout << "Enter your age: ";
    cin >> age;

    if (age < 0) {
        cout << "Invalid age";
    }
    else if (age <= 12) {
        cout << "Child";
    }
    else if (age <= 19) {
        cout << "Teenager";
    }
    else if (age <= 59) {
        cout << "Adult";
    }
    else {
        cout << "Senior Citizen";
    }

    return 0;
}


