Program 7 (Grade calculator)
#include <iostream>
using namespace std;

int main() {
    float marks;

    cout << "Enter your marks (out of 100): ";
    cin >> marks;

    if (marks >= 90) {
        cout << "Grade: A+";
    }
    else if (marks >= 80) {
        cout << "Grade: A";
    }
    else if (marks >= 70) {
        cout << "Grade: B";
    }
    else if (marks >= 60) {
        cout << "Grade: C";
    }
    else if (marks >= 50) {
        cout << "Grade: D";
    }
    else {
        cout << "Grade: F (Fail)";
    }

    return 0;
}

Program 8 (Leap year checker)
#include <iostream>
using namespace std;

int main() {
    int year;

    cout << "Enter a year: ";
    cin >> year;

    if ((year % 4 == 0 && year % 100 != 0) || (year % 400 == 0)) {
        cout << year << " is a Leap Year";
    } else {
        cout << year << " is not a Leap Year";
    }

    return 0;
}

