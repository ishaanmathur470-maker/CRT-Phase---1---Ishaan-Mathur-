Program 6 (Finding Odd number using do while loop)
#include <iostream>
using namespace std;

int main() {
    int i;
    cout << "ENTER A NUMBER: ";
    cin >> i;
    int y = 1;  
    do {
        if (y % 2 != 0) {
            cout << y << " ";
        }
        y++;   
    } while (y <= i);

    return 0;
}

Program 7 (Finding factorial of number)
#include <iostream>
using namespace std;

int main() {
    int n; 
    cout << "Please Enter The Value - : ";
    cin >> n;
    int fact = 1;
    
    for(int i = n; i >= 1; i --){
        fact = fact * i;
    }
    cout << " Factorial Will be - : " << fact;
    return 0;
}
