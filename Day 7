#include<iostream>
using namespace std;

class Rectangle {
public:
    int length;
    int width;

    // constructor - 1 (Default constructor)
    Rectangle() {
        length = 100;
        width = 209;
    }

    // constructor - 2 (Parameterized constructor)
    Rectangle(int l) {
        length = l;
        width = 209;
    }

    // constructor - 3 (Parameterized constructor)
    Rectangle(int l, int b) {
        length = l;
        width = b;
    }

    void area() {
        cout << width * length << endl;
    }
};

int main() {
    Rectangle r1;
    r1.area();

    Rectangle r2(100);
    r2.area();

    return 0;
}
